    { word: "wither away", ipa: "/ˈwɪðər əˈweɪ/", meaning: "héo úa, tàn lụi", example: "Without enough water, these delicate petals will soon wither away." },
    { word: "give off", ipa: "/ɡɪv ɒf/", meaning: "tỏa ra (mùi hương)", example: "Night-blooming jasmine gives off an incredibly sweet scent after sunset." },
    { word: "seasonal blooms", ipa: "/ˈsiːzənl bluːmz/", meaning: "hoa theo mùa", example: "I prefer buying seasonal blooms as they are more sustainable and fresh." },
    { word: "floral arrangement", ipa: "/ˈflɔːrəl əˈreɪndʒmənt/", meaning: "sắp xếp/cắm hoa", example: "She created a stunning floral arrangement for the wedding centerpiece." },
    { word: "delicate", ipa: "/ˈdelɪkət/", meaning: "mỏng manh, tinh tế", example: "Cherry blossoms are known for their delicate beauty and short lifespan." },
    { word: "cut back", ipa: "/kʌt bæk/", meaning: "tỉa bớt", example: "You should cut back the lavender after it finishes flowering to keep it tidy." },
    { word: "spring up", ipa: "/sprɪŋ ʌp/", meaning: "mọc lên nhanh chóng", example: "Wildflowers began to spring up all over the meadows as soon as the weather warmed." },
    { word: "perennial", ipa: "/pəˈreniəl/", meaning: "cây hoa lâu năm", example: "Perennials are a great investment because they come back year after year." },
    { word: "bouquet", ipa: "/buˈkeɪ/", meaning: "bó hoa", example: "He presented her with a massive bouquet of sun-drenched sunflowers." },
    { word: "exotic flowers", ipa: "/ɪɡˈzɒtɪk ˈflaʊərz/", meaning: "hoa ngoại nhập/kỳ lạ", example: "The botanical garden features a section dedicated to rare and exotic flowers." },
    { word: "petal", ipa: "/ˈpetl/", meaning: "cánh hoa", example: "The soft pink petals of the peony fell gently onto the grass." },
    { word: "die back", ipa: "/daɪ bæk/", meaning: "héo đi (nhưng rễ vẫn sống)", example: "Many bulb plants die back in autumn and remain dormant until spring." },
    { word: "stunning", ipa: "/ˈstʌnɪŋ/", meaning: "đẹp lộng lẫy", example: "The orchid display at the show was absolutely stunning." },
    { word: "nectar", ipa: "/ˈnektə(r)/", meaning: "mật hoa", example: "Bees and butterflies are attracted to flowers that produce high amounts of nectar." },
    { word: "blossom", ipa: "/ˈblɒsəm/", meaning: "hoa (thường là hoa cây ăn quả)", example: "The apple trees are covered in white blossom this time of year." },
    { word: "long-lasting", ipa: "/ˌlɒŋ ˈlɑːstɪŋ/", meaning: "tươi lâu", example: "Carnations are popular for bouquets because they are remarkably long-lasting." },
    { word: "symbolize", ipa: "/ˈsɪmbəlaɪz/", meaning: "tượng trưng cho", example: "In many cultures, white lilies symbolize purity and rebirth." }
  ];

  let favorites = JSON.parse(localStorage.getItem('flowerFavs')) || new Array(vocabList.length).fill(false);
  let currentCard = 0;
  let quizIndex = 0;
  let score = 0;
  let quizQuestions = [];
  let wrongItems = [];

  function speakText(text) {
    if (!window.speechSynthesis) return;
    const utterance = new SpeechSynthesisUtterance(text);
    utterance.lang = 'en-US';
    utterance.rate = 0.85;
    window.speechSynthesis.cancel();
    window.speechSynthesis.speak(utterance);
  }

  function updateFlashcard() {
    const item = vocabList[currentCard];
    document.getElementById('flashWord').innerText = item.word;
    document.getElementById('flashIpa').innerText = item.ipa;
    document.getElementById('flashMeaning').innerText = item.meaning;
    document.getElementById('flashExample').innerText = item.example;
    document.getElementById('flashProgress').innerText = `${currentCard + 1} / ${vocabList.length}`;
    document.getElementById('flipCard').classList.remove('flipped');
  }

  function renderTable(filter = 'all') {
    const tbody = document.getElementById('tableBody');
    tbody.innerHTML = '';
    vocabList.forEach((item, idx) => {
      if (filter === 'starred' && !favorites[idx]) return;
      const row = tbody.insertRow();
      row.innerHTML = `
        <td>${idx + 1}</td>
        <td><strong>${item.word}</strong></td>
        <td>${item.ipa}</td>
        <td><button onclick="speakText('${item.word.replace(/'/g, "\\'")}')">🔊</button></td>
        <td>${item.meaning}</td>
        <td>${item.example}</td>
        <td><button class="star-btn ${favorites[idx] ? 'active' : ''}" onclick="toggleStar(${idx}, this)">${favorites[idx] ? '⭐' : '☆'}</button></td>
      `;
    });
  }

  window.toggleStar = function(idx, btn) {
    favorites[idx] = !favorites[idx];
    localStorage.setItem('flowerFavs', JSON.stringify(favorites));
    btn.classList.toggle('active');
    btn.innerText = favorites[idx] ? '⭐' : '☆';
    if (document.getElementById('filterStarBtn').classList.contains('active') && !favorites[idx]) {
      renderTable('starred');
    }
  };

  // Controls
  document.getElementById('prevCardBtn').onclick = () => { currentCard = (currentCard - 1 + vocabList.length) % vocabList.length; updateFlashcard(); };
  document.getElementById('nextCardBtn').onclick = () => { currentCard = (currentCard + 1) % vocabList.length; updateFlashcard(); };
  document.getElementById('flipCard').onclick = () => document.getElementById('flipCard').classList.toggle('flipped');
  document.getElementById('playFlashAudio').onclick = (e) => { e.stopPropagation(); speakText(vocabList[currentCard].word); };
  document.getElementById('playExampleAudio').onclick = (e) => { e.stopPropagation(); speakText(vocabList[currentCard].example); };

  document.getElementById('filterAllBtn').onclick = function() {
    this.classList.add('active');
    document.getElementById('filterStarBtn').classList.remove('active');
    renderTable('all');
  };
  document.getElementById('filterStarBtn').onclick = function() {
    this.classList.add('active');
    document.getElementById('filterAllBtn').classList.remove('active');
    renderTable('starred');
  };

  // Quiz Logic
  function generateQuiz() {
    let qs = vocabList.map((item, i) => {
      const type = i % 3; // MC, Typing, Audio
      if (type === 0) {
        let options = [item.word];
        while (options.length < 4) {
          let r = vocabList[Math.floor(Math.random() * vocabList.length)].word;
          if (!options.includes(r)) options.push(r);
        }
        return { type: 'mc', q: `What is the English term for "${item.meaning}"?`, correct: item.word, options: options.sort() };
      } else if (type === 1) {
        return { type: 'fitb', q: `Translate to English: "${item.meaning}"`, correct: item.word };
      } else {
        return { type: 'audio', q: `Listen carefully and type the word:`, correct: item.word };
      }
    });
    return qs.sort(() => Math.random() - 0.5);
  }

  document.getElementById('startQuizBtn').onclick = () => {
    quizQuestions = generateQuiz();
    quizIndex = 0; score = 0; wrongItems = [];
    document.getElementById('quizArea').style.display = 'block';
    document.getElementById('resultArea').style.display = 'none';
    renderQuizQuestion();
  };

  function renderQuizQuestion() {
    const q = quizQuestions[quizIndex];
    let html = `<div class="pastel-card" style="text-align:center;"><h3>Question ${quizIndex + 1}/20</h3><p style="font-weight:600; margin-bottom:15px;">${q.q}</p>`;
    
    if (q.type === 'mc') {
      html += `<div class="quiz-options">` + q.options.map(opt => `<div class="quiz-option" onclick="checkAnswer('${opt}')">${opt}</div>`).join('') + `</div>`;
    } else if (q.type === 'fitb') {
      html += `<input type="text" id="quizInput" class="quiz-input" placeholder="Type answer..." onkeydown="if(event.key==='Enter') checkAnswer(this.value)"><br><button onclick="checkAnswer(document.getElementById('quizInput').value)">Check</button>`;
    } else if (q.type === 'audio') {
      html += `<button class="audio-quiz-btn" onclick="speakText('${q.correct.replace(/'/g, "\\'")}')">🔊 Play Sound</button><br>`;
      html += `<input type="text" id="quizInput" class="quiz-input" placeholder="What did you hear?" onkeydown="if(event.key==='Enter') checkAnswer(this.value)"><br><button onclick="checkAnswer(document.getElementById('quizInput').value)">Verify</button>`;
      setTimeout(() => speakText(q.correct), 400);
    }
    
    html += `<div id="quizFeedback" class="quiz-feedback"></div></div>`;
    document.getElementById('quizContainer').innerHTML = html;
    if (document.getElementById('quizInput')) document.getElementById('quizInput').focus();
  }

  window.checkAnswer = function(ans) {
    const q = quizQuestions[quizIndex];
    const isCorrect = ans.trim().toLowerCase() === q.correct.toLowerCase();
    const feedback = document.getElementById('quizFeedback');
    
    if (isCorrect) {
      score++;
      feedback.innerHTML = `<p class="correct">✔ Brilliant! That's correct.</p>`;
    } else {
      wrongItems.push({ q: q.correct, user: ans });
      feedback.innerHTML = `<p class="wrong">❌ Not quite. The word was: <strong>${q.correct}</strong></p>`;
    }
    
    setTimeout(() => {
      quizIndex++;
      if (quizIndex < 20) renderQuizQuestion();
      else showResults();
    }, 1500);
  };

  function showResults() {
    document.getElementById('quizArea').style.display = 'none';
    const res = document.getElementById('resultArea');
    res.style.display = 'block';
    res.innerHTML = `
      <div class="pastel-card" style="text-align:center;">
        <h2>Floral Quiz Results 🌸</h2>
        <p style="font-size:1.6rem; margin:15px 0;">Score: <strong>${score}/20</strong></p>
        ${wrongItems.length > 0 ? `
          <div style="text-align:left; background:#fff; padding:20px; border-radius:20px; margin-top:15px; border: 1px solid #f3e5f5;">
            <h4 style="color:#d81b60; margin-top:0;">Keep practicing these:</h4>
            <ul style="padding-left:20px; margin-bottom:0;">
              ${wrongItems.map(w => `<li><strong>${w.q}</strong> (Typed: <span style="color:#888; text-decoration:line-through;">${w.user || 'nothing'}</span>)</li>`).join('')}
            </ul>
          </div>` : '<p style="color:#2e7d32; font-weight:bold; font-size: 1.2rem;">Flawless! Your flower vocabulary is Band 9.0!</p>'}
        <button onclick="location.reload()" style="margin-top:25px;">Restart Quiz</button>
      </div>`;
  }

  // Initial load
  updateFlashcard();
  renderTable();
</script>]]></content><author><name></name></author><category term="learn-with-ms-thuy" /><category term="Vocabulary" /><category term="flowers" /><category term="ielts-speaking" /><category term="vocabulary" /><category term="interactive" /><summary type="html"><![CDATA[Master 20 sophisticated flower-related words and idioms for IELTS Speaking Band 7.0+ with our interactive tools.]]></summary></entry><entry><title type="html">🐾 Animals &amp;amp; Wildlife Vocabulary: Flashcards, Table &amp;amp; Quiz</title><link href="http://localhost:4000/learn-with-ms-thuy/learn-with-ms-thuy/vocabulary/animals/" rel="alternate" type="text/html" title="🐾 Animals &amp;amp; Wildlife Vocabulary: Flashcards, Table &amp;amp; Quiz" /><published>2026-04-20T00:00:00+07:00</published><updated>2026-04-20T00:00:00+07:00</updated><id>http://localhost:4000/learn-with-ms-thuy/learn-with-ms-thuy/vocabulary/animals</id><content type="html" xml:base="http://localhost:4000/learn-with-ms-thuy/learn-with-ms-thuy/vocabulary/animals/"><![CDATA[<style>
  /* ========== GLOBAL PASTEL GRADIENT STYLES ========== */
