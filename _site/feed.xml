    }
  ];

  // Thêm thành ngữ idioms (nếu muốn) nhưng không bắt buộc, tôi sẽ thêm 2 cái để phong phú
  vocabulary.push(
    {
      word: "cost an arm and a leg",
      phonetic: "/kɒst æn ɑːm ænd ə leɡ/",
      meaning: "Rất đắt đỏ",
      example: "That watch <strong>cost him an arm and a leg</strong>.",
      exampleTrans: "Chiếc đồng hồ đó tốn của anh ấy rất nhiều tiền."
    },
    {
      word: "shop around",
      phonetic: "/ʃɒp əˈraʊnd/",
      meaning: "Khảo giá (đi nhiều nơi để so giá)",
      example: "It's best to <strong>shop around</strong> before buying a new car.",
      exampleTrans: "Tốt nhất nên khảo giá trước khi mua xe mới."
    }
  );

  // --------------------------------------------------------------
  // FLASHCARD LOGIC
  // --------------------------------------------------------------
  let currentCardIndex = 0;
  const flashcardEl = document.getElementById('flashcard');
  const frontWord = document.getElementById('frontWord');
  const frontPhonetic = document.getElementById('frontPhonetic');
  const backMeaning = document.getElementById('backMeaning');
  const backExample = document.getElementById('backExample');
  const backExampleTrans = document.getElementById('backExampleTrans');
  const cardCounter = document.getElementById('cardCounter');

  function updateCardUI() {
    const card = vocabulary[currentCardIndex];
    frontWord.innerText = card.word;
    frontPhonetic.innerText = card.phonetic;
    backMeaning.innerText = card.meaning;
    // In đậm collocations: trong example ta đã có sẵn <strong> trong dữ liệu
    backExample.innerHTML = card.example;
    backExampleTrans.innerText = card.exampleTrans;
    cardCounter.innerText = `${currentCardIndex+1} / ${vocabulary.length}`;
    // Reset flip state về mặt trước khi chuyển thẻ
    if (flashcardEl.classList.contains('flipped')) {
      flashcardEl.classList.remove('flipped');
    }
  }

  // Audio sử dụng Web Speech API (đọc tự nhiên)
  function speakText(text, rate = 0.9) {
    if (!window.speechSynthesis) {
      alert("Trình duyệt của bạn không hỗ trợ đọc văn bản.");
      return;
    }
    const utterance = new SpeechSynthesisUtterance(text);
    utterance.lang = 'en-US';
    utterance.rate = rate; // 0.9 chậm hơn một chút
    utterance.pitch = 1;
    // Chọn giọng nữ nếu có
    window.speechSynthesis.cancel(); // dừng audio đang phát
    window.speechSynthesis.speak(utterance);
  }

  document.getElementById('playWordBtn').addEventListener('click', (e) => {
    e.stopPropagation();
    const word = vocabulary[currentCardIndex].word;
    speakText(word, 0.85);
  });
  document.getElementById('playExampleBtn').addEventListener('click', (e) => {
    e.stopPropagation();
    let exampleText = vocabulary[currentCardIndex].example.replace(/<[^>]*>/g, ''); // strip HTML tags
    speakText(exampleText, 0.8);
  });

  // Lật thẻ khi nhấp vào container
  document.getElementById('flashcardContainer').addEventListener('click', () => {
    flashcardEl.classList.toggle('flipped');
    // Tự động phát âm từ khi lật? Yêu cầu: "Tự động phát âm thanh khi lật hoặc chuyển thẻ"
    // Phát âm từ khi lật mặt trước? Ở đây ta phát âm từ khi lật (nếu đang ở mặt trước) hoặc câu ví dụ khi lật mặt sau? 
    // Để đáp ứng: khi lật (chuyển sang mặt sau) có thể phát câu ví dụ, nhưng yêu cầu nói "khi lật hoặc chuyển thẻ" -> phát âm từ.
    // Tôi sẽ phát âm từ khi lật (dễ dùng) và khi chuyển thẻ cũng phát từ.
    if (!flashcardEl.classList.contains('flipped')) {
      // vừa lật về mặt trước -> phát âm từ
      speakText(vocabulary[currentCardIndex].word, 0.85);
    } else {
      // lật sang mặt sau -> có thể phát câu ví dụ
      let exampleText = vocabulary[currentCardIndex].example.replace(/<[^>]*>/g, '');
      speakText(exampleText, 0.8);
    }
  });

  function changeCard(delta) {
    let newIndex = currentCardIndex + delta;
    if (newIndex < 0) newIndex = vocabulary.length - 1;
    if (newIndex >= vocabulary.length) newIndex = 0;
    currentCardIndex = newIndex;
    updateCardUI();
    // Phát âm từ mới (chuyển thẻ)
    speakText(vocabulary[currentCardIndex].word, 0.85);
  }

  document.getElementById('prevCardBtn').addEventListener('click', () => changeCard(-1));
  document.getElementById('nextCardBtn').addEventListener('click', () => changeCard(1));

  // Khởi tạo flashcard
  updateCardUI();

  // --------------------------------------------------------------
  // QUIZ LOGIC (dựa trên danh sách từ vựng)
  // --------------------------------------------------------------
  // Tạo câu hỏi: mỗi từ sẽ có 1 câu hỏi dạng "Nghĩa của từ X là gì?" với 4 lựa chọn (1 đúng, 3 sai ngẫu nhiên)
  const allWords = vocabulary.map(item => ({ word: item.word, meaning: item.meaning }));
  let quizQuestions = [];
  
  function generateQuizQuestions() {
    let qs = [];
    for (let i = 0; i < allWords.length; i++) {
      const correctMeaning = allWords[i].meaning;
      // Lấy 3 nghĩa sai khác (có thể trùng do ngẫu nhiên nhưng tạm ổn)
      let otherMeanings = allWords.filter((_, idx) => idx !== i).map(item => item.meaning);
      // Xáo trộn và lấy 3 cái
      otherMeanings = shuffleArray([...otherMeanings]);
      let options = [correctMeaning, ...otherMeanings.slice(0,3)];
      options = shuffleArray(options);
      qs.push({
        word: allWords[i].word,
        correctMeaning: correctMeaning,
        options: options
      });
    }
    return shuffleArray(qs); // xáo trộn thứ tự câu hỏi
  }

  function shuffleArray(arr) {
    for (let i = arr.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [arr[i], arr[j]] = [arr[j], arr[i]];
    }
    return arr;
  }

  let questions = generateQuizQuestions();
  let currentStep = 0; // 0: nhập tên, 1..N: câu hỏi, last: kết quả
  let userName = "";
  let userAnswers = new Array(questions.length).fill(null);
  let answerStatus = new Array(questions.length).fill(false);
  let selectedChoice = null;

  function playBeep(isCorrect) {
    try {
      const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
      const oscillator = audioCtx.createOscillator();
      const gainNode = audioCtx.createGain();
      oscillator.connect(gainNode);
      gainNode.connect(audioCtx.destination);
      oscillator.type = 'sine';
      oscillator.frequency.value = isCorrect ? 880 : 440;
      gainNode.gain.value = 0.2;
      oscillator.start();
      gainNode.gain.exponentialRampToValueAtTime(0.00001, audioCtx.currentTime + 0.5);
      oscillator.stop(audioCtx.currentTime + 0.3);
    } catch(e) { console.log("Audio not supported"); }
  }

  function renderQuiz() {
    const body = document.getElementById('quizBody');
    if (!body) return;
    if (currentStep === 0) {
      body.innerHTML = `
        <div style="text-align: center;">
          <p>👋 Nhập tên của bạn để bắt đầu quiz ôn tập ${questions.length} câu hỏi.</p>
          <input type="text" id="userNameInput" class="name-input" placeholder="Tên của bạn">
          <button id="startQuizBtn" class="start-btn">Bắt đầu làm bài →</button>
        </div>
      `;
      const startBtn = document.getElementById('startQuizBtn');
      const nameInput = document.getElementById('userNameInput');
      startBtn?.addEventListener('click', () => {
        const nameVal = nameInput.value.trim();
        if (!nameVal) { alert("Vui lòng nhập tên."); return; }
        userName = nameVal;
        currentStep = 1;
        renderQuiz();
      });
      return;
    }
    if (currentStep === questions.length + 1) {
      const totalCorrect = answerStatus.filter(v => v === true).length;
      body.innerHTML = `
        <div class="result-box">
          <p>🌟 <strong>${userName}</strong>, bạn đã hoàn thành quiz! 🌟</p>
          <p>Kết quả: <span class="score-number">${totalCorrect} / ${questions.length}</span></p>
          <p>${totalCorrect === questions.length ? "🎉 Hoàn hảo! Bạn đã nắm vững từ vựng." : "💪 Hãy ôn lại flashcards và thử lại."}</p>
          <button id="restartQuizBtn" class="restart-btn">🔄 Làm lại từ đầu</button>
        </div>
      `;
      document.getElementById('restartQuizBtn')?.addEventListener('click', () => {
        resetQuiz();
        renderQuiz();
      });
      return;
    }
    const qIndex = currentStep - 1;
    const q = questions[qIndex];
    const alreadyAnswered = userAnswers[qIndex] !== null;
    let feedbackHtml = "";
    if (alreadyAnswered) {
      const isCorrect = answerStatus[qIndex];
      feedbackHtml = `<div class="feedback ${isCorrect ? 'correct' : 'wrong'}">${isCorrect ? '✅ Đúng rồi!' : '❌ Sai rồi!'} ${!isCorrect ? `Đáp án đúng: ${q.correctMeaning}` : ''}</div>`;
    }
    let optionsHtml = "";
    q.options.forEach((opt, idx) => {
      optionsHtml += `<button class="option-btn" data-opt="${opt}" ${alreadyAnswered ? 'disabled' : ''}>${String.fromCharCode(65+idx)}. ${opt}</button>`;
    });
    body.innerHTML = `
      <div class="question-text">📌 Từ: <strong style="color:#f5576c;">${q.word}</strong><br>Nghĩa của từ này là gì?</div>
      <div class="options-list" id="optionsList">${optionsHtml}</div>
      ${feedbackHtml}
      ${alreadyAnswered ? `<button id="nextQuestionBtn" class="next-btn">Tiếp theo →</button>` : ""}
    `;
    if (!alreadyAnswered) {
      const optBtns = document.querySelectorAll('.option-btn');
      optBtns.forEach(btn => {
        btn.addEventListener('click', (e) => {
          if (userAnswers[qIndex] !== null) return;
          const selected = btn.dataset.opt;
          const isCorrect = (selected === q.correctMeaning);
          userAnswers[qIndex] = selected;
          answerStatus[qIndex] = isCorrect;
          playBeep(isCorrect);
          renderQuiz();
        });
      });
    } else {
      const nextBtn = document.getElementById('nextQuestionBtn');
      nextBtn?.addEventListener('click', () => {
        if (currentStep < questions.length) {
          currentStep++;
          renderQuiz();
        } else {
          currentStep = questions.length + 1;
          renderQuiz();
        }
      });
    }
  }

  function resetQuiz() {
    currentStep = 0;
    userName = "";
    userAnswers = new Array(questions.length).fill(null);
    answerStatus = new Array(questions.length).fill(false);
    // Tạo lại câu hỏi mới (xáo trộn)
    questions = generateQuizQuestions();
  }

  renderQuiz();
</script>]]></content><author><name></name></author><category term="learn-with-ms-thuy" /><category term="Vocabulary" /><category term="shopping" /><category term="flashcards" /><category term="quiz" /><category term="interactive" /><summary type="html"><![CDATA[Học từ vựng chủ đề Mua sắm qua flashcard lật và kiểm tra lại với quiz. Có phát âm tự động, ví dụ chi tiết.]]></summary></entry></feed>